{
  "name": "openbookdrive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp dist/index.html dist/app.html && cp landing-premium.html dist/index.html && cp vercel.json dist/ && cp -r images dist/",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
